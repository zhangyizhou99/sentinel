# 复制本文件为 .env 后填写真实值。.env 已被 .gitignore 忽略，绝不会提交。
# 只需填一个 provider 对应的 key 即可。

# 选择模型提供方：openai / deepseek / moonshot / github / copilot
SENTINEL_PROVIDER=openai

# 方式一：直接给统一 key（优先级最高，适用于任意 provider）
# SENTINEL_API_KEY=sk-xxxx

# 方式二：给对应 provider 的官方环境变量
# OPENAI_API_KEY=sk-xxxx
# DEEPSEEK_API_KEY=sk-xxxx
# MOONSHOT_API_KEY=sk-xxxx
# GITHUB_TOKEN=github_pat_xxxx
# COPILOT_API_KEY=placeholder

# 可选覆盖项
# SENTINEL_MODEL=gpt-4o-mini
# SENTINEL_BASE_URL=https://api.openai.com/v1
# SENTINEL_TEMPERATURE=0.2

# 本地 copilot-api 代理示例：
# SENTINEL_PROVIDER=copilot
# SENTINEL_API_KEY=placeholder
# SENTINEL_MODEL=gpt-4o
# SENTINEL_BASE_URL=http://127.0.0.1:4141/v1

# 本地协作原型：同一 user_id 代表同一用户；同一 workspace_id 共享项目/任务记忆。
# SENTINEL_USER_ID=alice
# SENTINEL_USER_NAME=Alice
# SENTINEL_WORKSPACE_ID=team-alpha
# SENTINEL_WORKSPACE_NAME=Team Alpha
# SENTINEL_WORKSPACE_ROOT=d:\Code

# Grafana dashboard 部署（deploy_dashboard 专用；仅在用户明确同意部署时使用）
# GRAFANA_URL=https://grafana.example.com
# GRAFANA_TOKEN=glsa_xxx
# GRAFANA_FOLDER_UID=sentinel
# GRAFANA_DATASOURCE_UID=prometheus
